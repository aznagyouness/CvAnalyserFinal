# Redis Configuration Example
REDIS_PASSWORD=minirag_redis_2222

# Persistence
REDIS_APPENDONLY=yes

# Memory Management
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# Security
REDIS_PROTECTED_MODE=yes

#changing the port that redis listens on to much the container port mapping
REDIS_PORT=6426  # ← Now port can be here