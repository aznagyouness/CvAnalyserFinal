# RabbitMQ Configuration Example
RABBITMQ_DEFAULT_USER=minirag_user
RABBITMQ_DEFAULT_PASS=minirag_rabbitmq_0000
RABBITMQ_DEFAULT_VHOST=minirag_vhost

# Management Plugin
RABBITMQ_MANAGEMENT_ENABLED=true

# Security
RABBITMQ_AUTH_BACKENDS=rabbit_auth_backend_internal

# Performance
RABBITMQ_DISK_FREE_LIMIT=2000000000

#changing the port that rabbitmq listens on to much the container port mapping
RABBITMQ_NODE_PORT=5821  
