# ========================= General Config =========================
# ========================= File Config =========================
FILE_ALLOWED_TYPES=["text/plain", "application/pdf"]
FILE_MAX_SIZE=100
FILE_DEFAULT_CHUNK_SIZE=1048576 # 1 MB

# ========================= Celery Task Queue Config =========================
CELERY_BROKER_URL="amqp://minirag_user:minirag_rabbitmq_0000@localhost:5821/minirag_vhost"
CELERY_RESULT_BACKEND_URL="redis://:minirag_redis_2222@localhost:6426/0"
CELERY_TASK_SERIALIZER="json"
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_ACKS_LATE=false
CELERY_WORKER_CONCURRENCY=8


# ========================= Database Config =========================


# PostgreSQL Config
